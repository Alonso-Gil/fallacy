generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model app_parameters {
  id                 String   @id(map: "features_pkey") @db.Uuid
  out_of_service_web Boolean? @default(false)
}

model message {
  id          String    @id(map: "message_pk") @db.Uuid
  author_data Json?     @db.Json
  message     String?   @db.VarChar
  created_at  DateTime? @db.Timestamp(6)
  room_id     String?   @db.Uuid
  room        room?     @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "message_room_fk")
}

model room {
  id                      String    @id(map: "room_pk") @db.Uuid
  title                   String?   @db.VarChar(255)
  description             String?   @db.VarChar(255)
  defender                String?   @db.VarChar
  challenger              String?   @db.VarChar
  moderator               String?   @db.VarChar
  is_private              Boolean?
  interval_beetwen_speech Int?      @default(3)
  defender_marks          Int?
  challenger_marks        Int?
  finished                Boolean?
  defender_votes          Int?
  challenger_votes        Int?
  abstent_votes           Int?
  message                 message[]
}
