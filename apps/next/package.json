{
  "name": "fallacy-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "next start",
    "dev": "next dev --turbopack",
    "compile": "echo skipping compile",
    "build": "next build",
    "clean": "rm -rf .next && rm -rf node_modules",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:ci": "eslint . --ext .ts,.tsx --max-warnings 0",
    "check-types": "tsc",
    "test": "vitest run",
    "prettier": "prettier --ignore-path .prettierignore \"src/**/*.{js,jsx,ts,tsx,json,css,scss,html}\" \"messages/**/*.json\" \"src/proxy.ts\" \"*.{ts,tsx,js,mjs,cjs,json}\"",
    "format": "yarn prettier --write",
    "check-format": "yarn prettier --list-different"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fallacy/types": "*",
    "@hookform/resolvers": "^3.10.0",
    "@supabase/ssr": "^0.10.2",
    "@tanstack/react-query": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.0",
    "@types/react-dom": "^19.2.0",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.9",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.2.2"
  }
}
