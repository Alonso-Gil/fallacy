{
  "name": "@fallacy/types",
  "version": "0.0.0",
  "description": "Fallacy types and interfaces",
  "private": true,
  "main": "./dist/bundle.cjs.js",
  "module": "./dist/bundle.esm.js",
  "types": "./dist/bundle.d.ts",
  "scripts": {
    "start": "echo skipping",
    "compile": "rollup -c",
    "dev": "yarn compile -w",
    "clean": "rimraf dist",
    "prebuild": "yarn clean",
    "build": "yarn compile",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:ci": "eslint . --ext .ts,.tsx",
    "prettier": "prettier --ignore-path .prettierignore \"src/**/*.ts\" \"*.{js,mjs,json}\"",
    "format": "yarn prettier --write",
    "check-format": "yarn prettier --list-different"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
