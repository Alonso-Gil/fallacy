{
  "name": "fallacy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:next": "yarn workspace fallacy-web dev",
    "dev:nest": "yarn workspace fallacy-nest start:dev",
    "clean": "rm -rf node_modules && rm -rf packages/**/node_modules && rm -rf apps/**/node_modules && yarn clean:cache",
    "clean:cache": "rm -rf packages/**/.turbo && rm -rf apps/**/.turbo && rm -rf apps/**/.next",
    "compile": "turbo run compile",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "format": "turbo run format",
    "check-format": "turbo run check-format",
    "start:next": "yarn compile && yarn workspace fallacy-web dev",
    "start:nest": "yarn compile && yarn workspace fallacy-nest start:dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "zod": "^3.24.2"
  },
  "resolutions": {
    "es-iterator-helpers": "1.2.1",
    "internal-slot": "1.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@rollup/plugin-commonjs": "^24.1.0",
    "@rollup/plugin-inject": "^5.0.3",
    "@rollup/plugin-json": "^6.0.0",
    "esbuild": "^0.25.2",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "rollup": "^2.77.1",
    "rollup-plugin-dts": "^5.3.0",
    "rollup-plugin-esbuild": "^5.0.0",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^1.10.12",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "packageManager": "yarn@1.22.19"
}
