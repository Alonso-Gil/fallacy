{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "compile": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "check-types": {
      "dependsOn": ["^build", "compile"],
      "inputs": ["src/**/*"]
    },
    "lint": {},
    "lint:ci": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "check-format": {}
  }
}
